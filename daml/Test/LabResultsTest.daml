module Test.LabResultsTest where

import Types
import HealthRecord
import AccessGrants
import DiagnosticAccess
import DA.Date hiding (date)
import DA.Time
import DoctorAccess
import Daml.Script

-- Test 13 & 14: Lab results are recorded in HealthRecord history
test_labResultsRecordedInHistory = do
  patient <- allocateParty "Alice"
  drSmith <- allocateParty "DrSmith"
  labCorp <- allocateParty "LabCorp"

  setTime (time (mkDate 2025 Jan 15) 9 0 0)

  healthRecord <- submit patient do
    createCmd HealthRecord with
      patient = patient
      patientInfo = PatientInfo with
        name = "Alice Johnson"
        dateOfBirth = mkDate 1985 Jun 12
        bloodType = "O+"
        emergencyContact = "Bob Johnson (spouse) - 555-0123"
      allergies = []
      conditions = []
      medications = []
      surgeries = []
      illnesses = []
      diagnosticHistory = []
      prescriptionHistory = []
      dispenseHistory = []
      immunizations = []
      familyHistory = []

  accessManager <- submit patient do
    createCmd PatientAccessManager with
      patient = patient

  -- Setup: create lab order, diagnostic access, and lab results
  doctorAccess <- submit patient do
    exerciseCmd accessManager GrantDoctorAccess with
      healthRecordCid = healthRecord
      doctor = drSmith
      duration = Days30

  labOrder <- submit drSmith do
    exerciseCmd doctorAccess CreateLabOrder with
      labType = BloodWork
      reason = "Routine blood panel"

  diagnosticAccess <- submit patient do
    exerciseCmd accessManager GrantDiagnosticAccess with
      healthRecordCid = healthRecord
      diagnosticCenter = labCorp
      labOrderCid = labOrder

  -- Submit lab results
  _labReport <- submit labCorp do
    exerciseCmd diagnosticAccess SubmitLabResults with
      findings = "CBC normal. Cholesterol slightly elevated at 210."
      resultDate = mkDate 2025 Jan 20

  -- 13. Verify the lab result report was created
  -- (Re-grant doctor access to check the snapshot)
  doctorAccess2 <- submit patient do
    exerciseCmd accessManager GrantDoctorAccess with
      healthRecordCid = healthRecord
      doctor = drSmith
      duration = Days30

  -- 14. Revoke doctor access
  submit patient do
    exerciseCmd doctorAccess2 RevokeDoctorAccess

  return ()
