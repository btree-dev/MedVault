module Test.PharmacyAccessTest where

import Types
import HealthRecord
import AccessGrants
import PharmacyAccess
import DA.Date hiding (date)
import DA.Time
import DoctorAccess
import Daml.Script

-- Test 8 & 9: Pharmacy access grant and dispensing acknowledgment
test_pharmacyAccessAndDispensing = do
  patient <- allocateParty "Alice"
  drSmith <- allocateParty "DrSmith"
  pharmacy <- allocateParty "PharmaCorp"

  setTime (time (mkDate 2025 Jan 15) 9 0 0)

  healthRecord <- submit patient do
    createCmd HealthRecord with
      patient = patient
      authorizedParties = []
      patientInfo = PatientInfo with
        name = "Alice Johnson"
        dateOfBirth = mkDate 1985 Jun 12
        bloodType = "O+"
        emergencyContact = "Bob Johnson (spouse) - 555-0123"
      allergies =
        [ Allergy with name = "Penicillin"; severity = "severe"; reaction = "Anaphylaxis"
        ]
      conditions = []
      medications =
        [ Medication with
            name = "Lisinopril"
            dosage = "10mg"
            frequency = "daily"
            prescribedDate = mkDate 2020 Mar 15
            prescribedBy = "Dr. Williams"
        ]
      surgeries = []
      illnesses = []
      diagnosticHistory = []
      prescriptionHistory = []
      dispenseHistory = []
      immunizations = []
      familyHistory = []

  accessManager <- submit patient do
    createCmd PatientAccessManager with
      patient = patient

  -- Grant doctor access and create prescription
  doctorAccess <- submit patient do
    exerciseCmd accessManager GrantDoctorAccess with
      healthRecordCid = healthRecord
      doctor = drSmith
      duration = Days30

  -- Get updated HR cid after grant (AddAuthorizedParty consumed old one)
  [(hrCid1, _)] <- query @HealthRecord patient

  prescription <- submit drSmith do
    exerciseCmd doctorAccess CreatePrescription with
      medication = Medication with
        name = "Amoxicillin"
        dosage = "500mg"
        frequency = "3x daily"
        prescribedDate = mkDate 2025 Jan 15
        prescribedBy = "DrSmith"
      notes = "For bacterial infection."
      healthRecordCid = hrCid1

  -- Get updated HR cid after prescription (RecordPrescriptionInHistory consumed old one)
  [(hrCid2, _)] <- query @HealthRecord patient

  -- 8. Patient grants pharmacy access to prescription
  pharmacyAccess <- submit patient do
    exerciseCmd accessManager GrantPharmacyAccess with
      healthRecordCid = hrCid2
      pharmacy = pharmacy
      prescriptionCid = prescription

  -- Get updated HR cid after pharmacy grant
  [(hrCid3, _)] <- query @HealthRecord patient

  -- 9. Pharmacy acknowledges dispensing (creates DispenseEntry)
  _dispenseEntry <- submit pharmacy do
    exerciseCmd pharmacyAccess AcknowledgeDispensing with
      dispensingNote = "Dispensed as prescribed"
      markAsFilled = True
      healthRecordCid = hrCid3

  return ()

-- Test: Patient revokes pharmacy access before dispensing
test_revokePharmacyAccess = do
  patient <- allocateParty "Alice"
  drSmith <- allocateParty "DrSmith"
  pharmacy <- allocateParty "PharmaCorp"

  setTime (time (mkDate 2025 Jan 15) 9 0 0)

  healthRecord <- submit patient do
    createCmd HealthRecord with
      patient = patient
      authorizedParties = []
      patientInfo = PatientInfo with
        name = "Alice Johnson"
        dateOfBirth = mkDate 1985 Jun 12
        bloodType = "O+"
        emergencyContact = "Bob Johnson (spouse) - 555-0123"
      allergies = []
      conditions = []
      medications = []
      surgeries = []
      illnesses = []
      diagnosticHistory = []
      prescriptionHistory = []
      dispenseHistory = []
      immunizations = []
      familyHistory = []

  accessManager <- submit patient do
    createCmd PatientAccessManager with
      patient = patient

  doctorAccess <- submit patient do
    exerciseCmd accessManager GrantDoctorAccess with
      healthRecordCid = healthRecord
      doctor = drSmith
      duration = Days30

  [(hrCid1, _)] <- query @HealthRecord patient

  prescription <- submit drSmith do
    exerciseCmd doctorAccess CreatePrescription with
      medication = Medication with
        name = "Amoxicillin"
        dosage = "500mg"
        frequency = "3x daily"
        prescribedDate = mkDate 2025 Jan 15
        prescribedBy = "DrSmith"
      notes = "For bacterial infection."
      healthRecordCid = hrCid1

  [(hrCid2, _)] <- query @HealthRecord patient

  pharmacyAccess <- submit patient do
    exerciseCmd accessManager GrantPharmacyAccess with
      healthRecordCid = hrCid2
      pharmacy = pharmacy
      prescriptionCid = prescription

  -- Patient revokes pharmacy access
  submit patient do
    exerciseCmd pharmacyAccess RevokePharmacyAccess

  [(hrCid3, _)] <- query @HealthRecord patient

  -- Pharmacy cannot dispense after revocation
  submitMustFail pharmacy do
    exerciseCmd pharmacyAccess AcknowledgeDispensing with
      dispensingNote = "Should fail"
      markAsFilled = False
      healthRecordCid = hrCid3

  return ()

-- Test: Pharmacy dispenses without marking as filled
test_pharmacyDispenseWithoutFilled = do
  patient <- allocateParty "Alice"
  drSmith <- allocateParty "DrSmith"
  pharmacy <- allocateParty "PharmaCorp"

  setTime (time (mkDate 2025 Jan 15) 9 0 0)

  healthRecord <- submit patient do
    createCmd HealthRecord with
      patient = patient
      authorizedParties = []
      patientInfo = PatientInfo with
        name = "Alice Johnson"
        dateOfBirth = mkDate 1985 Jun 12
        bloodType = "O+"
        emergencyContact = "Bob Johnson (spouse) - 555-0123"
      allergies = []
      conditions = []
      medications = []
      surgeries = []
      illnesses = []
      diagnosticHistory = []
      prescriptionHistory = []
      dispenseHistory = []
      immunizations = []
      familyHistory = []

  accessManager <- submit patient do
    createCmd PatientAccessManager with
      patient = patient

  doctorAccess <- submit patient do
    exerciseCmd accessManager GrantDoctorAccess with
      healthRecordCid = healthRecord
      doctor = drSmith
      duration = Days30

  [(hrCid1, _)] <- query @HealthRecord patient

  prescription <- submit drSmith do
    exerciseCmd doctorAccess CreatePrescription with
      medication = Medication with
        name = "Ibuprofen"
        dosage = "400mg"
        frequency = "as needed"
        prescribedDate = mkDate 2025 Jan 15
        prescribedBy = "DrSmith"
      notes = "For pain relief"
      healthRecordCid = hrCid1

  [(hrCid2, _)] <- query @HealthRecord patient

  pharmacyAccess <- submit patient do
    exerciseCmd accessManager GrantPharmacyAccess with
      healthRecordCid = hrCid2
      pharmacy = pharmacy
      prescriptionCid = prescription

  [(hrCid3, _)] <- query @HealthRecord patient

  -- Pharmacy dispenses without marking as filled (partial fill)
  _dispenseEntry <- submit pharmacy do
    exerciseCmd pharmacyAccess AcknowledgeDispensing with
      dispensingNote = "Partial fill - 15 tablets dispensed"
      markAsFilled = False
      healthRecordCid = hrCid3

  return ()
