module Test.DiagnosticAccessTest where

import Types
import HealthRecord
import AccessGrants
import DiagnosticAccess
import DA.Date hiding (date)
import DA.Time
import DoctorAccess
import Daml.Script

-- Test 10, 11, 12: Diagnostic center access, lab results submission, empty findings fail
test_diagnosticAccessAndResults = do
  patient <- allocateParty "Alice"
  drSmith <- allocateParty "DrSmith"
  labCorp <- allocateParty "LabCorp"

  setTime (time (mkDate 2025 Jan 15) 9 0 0)

  healthRecord <- submit patient do
    createCmd HealthRecord with
      patient = patient
      authorizedParties = []
      patientInfo = PatientInfo with
        name = "Alice Johnson"
        dateOfBirth = mkDate 1985 Jun 12
        bloodType = "O+"
        emergencyContact = "Bob Johnson (spouse) - 555-0123"
      allergies = []
      conditions = []
      medications = []
      surgeries = []
      illnesses = []
      diagnosticHistory = []
      prescriptionHistory = []
      dispenseHistory = []
      immunizations = []
      familyHistory = []

  accessManager <- submit patient do
    createCmd PatientAccessManager with
      patient = patient

  -- Grant doctor access and create lab order
  doctorAccess <- submit patient do
    exerciseCmd accessManager GrantDoctorAccess with
      healthRecordCid = healthRecord
      doctor = drSmith
      duration = Days30

  [(hrCid1, _)] <- query @HealthRecord patient

  labOrder <- submit drSmith do
    exerciseCmd doctorAccess CreateLabOrder with
      labType = BloodWork
      reason = "Routine blood panel for hypertension monitoring"
      healthRecordCid = hrCid1

  [(hrCid2, _)] <- query @HealthRecord patient

  -- 10. Patient grants diagnostic center access to lab order
  diagnosticAccess <- submit patient do
    exerciseCmd accessManager GrantDiagnosticAccess with
      healthRecordCid = hrCid2
      diagnosticCenter = labCorp
      labOrderCid = labOrder

  [(hrCid3, _)] <- query @HealthRecord patient

  -- 11. Diagnostic center submits lab results
  _labReport <- submit labCorp do
    exerciseCmd diagnosticAccess SubmitLabResults with
      findings = "CBC normal. Cholesterol slightly elevated at 210."
      resultDate = mkDate 2025 Jan 20
      healthRecordCid = hrCid3

  -- 12. Empty findings should fail - need a new diagnostic access since the previous one was consumed
  [(hrCid4, _)] <- query @HealthRecord patient

  labOrder2 <- submit drSmith do
    exerciseCmd doctorAccess CreateLabOrder with
      labType = BloodWork
      reason = "Follow-up blood panel"
      healthRecordCid = hrCid4

  [(hrCid5, _)] <- query @HealthRecord patient

  diagnosticAccess2 <- submit patient do
    exerciseCmd accessManager GrantDiagnosticAccess with
      healthRecordCid = hrCid5
      diagnosticCenter = labCorp
      labOrderCid = labOrder2

  [(hrCid6, _)] <- query @HealthRecord patient

  submitMustFail labCorp do
    exerciseCmd diagnosticAccess2 SubmitLabResults with
      findings = ""
      resultDate = mkDate 2025 Jan 20
      healthRecordCid = hrCid6

  return ()

-- Test: Patient revokes diagnostic access before results are submitted
test_revokeDiagnosticAccess = do
  patient <- allocateParty "Alice"
  drSmith <- allocateParty "DrSmith"
  labCorp <- allocateParty "LabCorp"

  setTime (time (mkDate 2025 Jan 15) 9 0 0)

  healthRecord <- submit patient do
    createCmd HealthRecord with
      patient = patient
      authorizedParties = []
      patientInfo = PatientInfo with
        name = "Alice Johnson"
        dateOfBirth = mkDate 1985 Jun 12
        bloodType = "O+"
        emergencyContact = "Bob Johnson (spouse) - 555-0123"
      allergies = []
      conditions = []
      medications = []
      surgeries = []
      illnesses = []
      diagnosticHistory = []
      prescriptionHistory = []
      dispenseHistory = []
      immunizations = []
      familyHistory = []

  accessManager <- submit patient do
    createCmd PatientAccessManager with
      patient = patient

  doctorAccess <- submit patient do
    exerciseCmd accessManager GrantDoctorAccess with
      healthRecordCid = healthRecord
      doctor = drSmith
      duration = Days30

  [(hrCid1, _)] <- query @HealthRecord patient

  labOrder <- submit drSmith do
    exerciseCmd doctorAccess CreateLabOrder with
      labType = MRI
      reason = "Brain MRI for persistent headaches"
      healthRecordCid = hrCid1

  [(hrCid2, _)] <- query @HealthRecord patient

  diagnosticAccess <- submit patient do
    exerciseCmd accessManager GrantDiagnosticAccess with
      healthRecordCid = hrCid2
      diagnosticCenter = labCorp
      labOrderCid = labOrder

  -- Patient revokes diagnostic access
  submit patient do
    exerciseCmd diagnosticAccess RevokeDiagnosticAccess

  [(hrCid3, _)] <- query @HealthRecord patient

  -- Diagnostic center cannot submit results after revocation
  submitMustFail labCorp do
    exerciseCmd diagnosticAccess SubmitLabResults with
      findings = "Should fail - access revoked"
      resultDate = mkDate 2025 Jan 20
      healthRecordCid = hrCid3

  return ()
