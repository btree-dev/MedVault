module Test.DiagnosticAccessTest where

import Types
import HealthRecord
import DiagnosticAccess
import DA.Date hiding (date)
import DA.Time
import DoctorAccess
import Daml.Script

-- Test 10, 11, 12: Diagnostic center access, lab results submission, empty findings fail
test_diagnosticAccessAndResults = do
  patient <- allocateParty "Alice"
  drSmith <- allocateParty "DrSmith"
  labCorp <- allocateParty "LabCorp"

  setTime (time (mkDate 2025 Jan 15) 9 0 0)

  healthRecord <- submit patient do
    createCmd HealthRecord with
      patient = patient
      patientInfo = PatientInfo with
        name = "Alice Johnson"
        dateOfBirth = mkDate 1985 Jun 12
        bloodType = "O+"
        emergencyContact = "Bob Johnson (spouse) - 555-0123"
      allergies = []
      conditions = []
      medications = []
      surgeries = []
      illnesses = []
      diagnosticHistory = []
      prescriptionHistory = []
      immunizations = []
      familyHistory = []

  -- Grant doctor access and create lab order
  doctorAccess <- submit patient do
    exerciseCmd healthRecord GrantDoctorAccess with
      doctor = drSmith
      duration = Days30

  labOrder <- submit drSmith do
    exerciseCmd doctorAccess CreateLabOrder with
      labType = BloodWork
      reason = "Routine blood panel for hypertension monitoring"

  -- 10. Patient grants diagnostic center access to lab order
  diagnosticAccess <- submit patient do
    exerciseCmd healthRecord GrantDiagnosticAccess with
      diagnosticCenter = labCorp
      labOrderCid = labOrder

  -- 11. Diagnostic center submits lab results
  _labReport <- submit labCorp do
    exerciseCmd diagnosticAccess SubmitLabResults with
      findings = "CBC normal. Cholesterol slightly elevated at 210."
      resultDate = mkDate 2025 Jan 20

  -- 12. Empty findings should fail
  diagnosticAccess2 <- submit patient do
    exerciseCmd healthRecord GrantDiagnosticAccess with
      diagnosticCenter = labCorp
      labOrderCid = labOrder

  submitMustFail labCorp do
    exerciseCmd diagnosticAccess2 SubmitLabResults with
      findings = ""
      resultDate = mkDate 2025 Jan 20

  return ()
